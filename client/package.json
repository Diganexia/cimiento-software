{
  "name": "ferreteria-client",
  "version": "1.1.8",
  "description": "Cimiento — Sistema de gestión para ferreterías y corralones",
  "author": "Diganexia",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:server": "SERVER_MODE=true vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:dev:server": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development SERVER_MODE=true electron .\"",
    "electron:build": "vite build && electron-builder --config electron-builder-unified.json",
    "electron:build:client": "vite build && electron-builder --config electron-builder-client.json",
    "electron:build:server": "vite build && electron-builder --config electron-builder-server.json"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.8.3",
    "embedded-postgres": "^18.3.0-beta.17",
    "express": "^4.18.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "node-afip": "^1.0.0",
    "pdfkit": "^0.15.2",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "recharts": "^2.12.7",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.4.6",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.6",
    "wait-on": "^7.2.0"
  }
}
