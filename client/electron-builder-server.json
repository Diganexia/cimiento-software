{
  "appId": "com.ferreteria.servidor",
  "productName": "Corralon Servidor",
  "electronVersion": "29.4.6",
  "copyright": "Ferretería Software",
  "directories": {
    "output": "dist-electron/server"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "../server",
      "to": "server",
      "filter": ["**/*", "!**/.env", "!**/.env.*", "!**/nodemon.json"]
    },
    {
      "from": "electron/server-mode.flag",
      "to": "server-mode.flag"
    }
  ],
  "win": {
    "target": [{ "target": "nsis", "arch": ["x64"] }],
    "icon": "assets/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "assets/icon.ico",
    "installerHeaderIcon": "assets/icon.ico",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Corralon Servidor"
  },
  "toolsets": {
    "winCodeSign": "1.1.0"
  },
  "extraMetadata": {
    "main": "electron/main.js"
  },
  "publish": {
    "provider": "github",
    "owner": "Diganexia",
    "repo": "ferreteria-software",
    "channel": "server"
  }
}
